# Server
SPATIAL_SERVER_PORT=8080
SPATIAL_SERVER_MODE=debug

# PostgreSQL + PostGIS
SPATIAL_DATABASE_HOST=localhost
SPATIAL_DATABASE_PORT=5432
SPATIAL_DATABASE_USER=spatial
SPATIAL_DATABASE_PASSWORD=spatial
SPATIAL_DATABASE_DBNAME=spatial_memory
SPATIAL_DATABASE_SSLMODE=disable

# Redis
SPATIAL_REDIS_HOST=localhost
SPATIAL_REDIS_PORT=6379
SPATIAL_REDIS_PASSWORD=
SPATIAL_REDIS_DB=0

# JWT
SPATIAL_JWT_SECRET=change-me-in-production
SPATIAL_JWT_ACCESS_EXPIRATION=2h
SPATIAL_JWT_REFRESH_EXPIRATION=720h

# Cloudflare R2 (S3-compatible)
SPATIAL_R2_ACCOUNT_ID=
SPATIAL_R2_ACCESS_KEY_ID=
SPATIAL_R2_ACCESS_KEY_SECRET=
SPATIAL_R2_BUCKET=spatial-memory
SPATIAL_R2_PUBLIC_URL=

# SMS Provider
SPATIAL_SMS_PROVIDER=aliyun
SPATIAL_SMS_API_KEY=
SPATIAL_SMS_API_SECRET=
SPATIAL_SMS_SIGN_NAME=

# WeChat OAuth
SPATIAL_WECHAT_APP_ID=
SPATIAL_WECHAT_APP_SECRET=

# GLM-4V Moderation (ZhipuAI)
SPATIAL_GLM_API_KEY=
SPATIAL_GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
SPATIAL_GLM_TIMEOUT=30s
